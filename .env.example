# ==========================================
# RESET MUSIC - ENVIRONMENT VARIABLES
# ==========================================

# 1. MongoDB Database
# Use your MongoDB Atlas connection string here.
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/resetmusic?retryWrites=true&w=majority"

# 2. Authentication
# Generate a strong random string for JWT signing. 
# You can generate one using: `openssl rand -base64 32`
JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"

# 3. AWS S3 (For Image Uploads)
# Create an IAM User in AWS with S3 full access and put the keys here.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_S3_BUCKET_NAME="your-s3-bucket-name"
